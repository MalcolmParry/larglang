label print;
thing = 5;
strdef msg, len =
\\hello world
;

fn test4(n) {
	thing = thing + n;

    i = 0 + 0;
    x = 5;
    y = 0;

	print(msg, len);

    while (i < n) {
        y = x * 2;
        i = i + 1;
    }

    return y;
}

asm(
	\\.section .text
	\\.global _start

	\\_start:
	\\	mov rdi, 7
	\\	call test4
	\\	mov rdi, rax
	\\	mov rax, 60
	\\	syscall

	\\print:
	\\	mov rdx, rsi
	\\	mov rsi, rdi
	\\	mov rax, 1
	\\	mov rdi, 2
	\\	syscall
	\\	ret
);
