label print;
thing = 5;
strdef msg, msg_len =
\\hello world
\\
;

fn printNum(n) {
	rbuffer = stack_alloc 20;
	len = 0;

	if (n == 0) {
		^rbuffer = 48;
		print(rbuffer, 1);
		return 0;
	}

	while (n != 0) {
		mod = n - (n / 10 * 10);
		^(rbuffer + len) = 48 + mod;
		n = n / 10;
		len = len + 1;
	}

	buffer = stack_alloc 20;
	i = 0;
	while (i < len) {
		^(buffer + i) = ^(rbuffer + len - i - 1);
		i = i + 1;
	}

	print(buffer, len);
}

label fact;
fn fact(n) {
	if (n == 1) {
		return 1;
	}

	return n * fact(n - 1);
}

label exit;
export fn _start() {
	printNum(fact(5));

	exit(0);
}

asm(
	\\.section .text
	\\print:
	\\	mov rdx, rsi
	\\	mov rsi, rdi
	\\	mov rax, 1
	\\	mov rdi, 2
	\\	syscall
	\\	ret

	\\exit:
	\\	mov rax, 60
	\\	syscall
);
