}

fn test3(n) {
    i = 0;
    sum = 0;

    while (i < n) {
        sum = sum + i;
        i = i + 1;
    }

    return sum;
}

fn test4(n) {
    i = 0 + 0;
    x = 5;
    y = 0;

    while (i < n) {
        y = x * 2;
        i = i + 1;
    }

    return y;
}
